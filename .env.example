# =============================================================================
# Shopify — 与代码中变量名一致；生产环境在 Vercel 等处同名配置。
# 详见 docs/shopify-deployment.md、docs/shopify-admin-setup.md
# =============================================================================

# 店铺：务必使用 *.myshopify.com（不要用自定义域作为主配置）
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_DOMAIN=your-store.myshopify.com

# Storefront API：来自 Headless / 自定义店面渠道（不是自定义应用的 Client ID）
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# Admin API：自定义应用后台的「Admin API access token」（界面为准，常见 shpat_）
# 勿将 OAuth「Client secret」（如 shpss_...）误填于此
SHOPIFY_ADMIN_TOKEN=shpat_xxx

# Webhook：在 Shopify 创建 Webhook 时配置的签名密钥，须与后台一致
SHOPIFY_WEBHOOK_SECRET=your-webhook-signing-secret

# 调用 POST /api/revalidate 时 JSON body.secret 须与此相同
REVALIDATE_SECRET=your-revalidate-secret

# 微信公众号（服务号）— 可选
WECHAT_APPID=wxXXXXXXXX
WECHAT_SECRET=your-wechat-secret

# 管理员配置 — 可选
ADMIN_OPENIDS=oXXXXX1,oXXXXX2
DEV_ADMIN_OPENID=dev-local-admin
